// Load batch details for log form
function loadBatchDetails() {
    const batchId = document.getElementById('logBatch').value;
    const summaryDiv = document.getElementById('batchSummary');
    
    if (!batchId) {
        summaryDiv.style.display = 'none';
        // Clear prefilled inputs and make them editable
        const receivedInput = document.getElementById('logReceived');
        if (receivedInput) {
            receivedInput.value = '';
            receivedInput.readOnly = false;
            receivedInput.classList.remove('bg-light');
        }
        document.getElementById('calcTotal').textContent = 0;
        document.getElementById('calcNewPending').textContent = 0;
        document.getElementById('calcEfficiency').textContent = '0%';
        return;
    }
    
    fetch(`<?= base_url('/production/ajax-get-batch-summary/') ?>${batchId}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const batch = data.batch;
                document.getElementById('summaryPlanned').textContent = batch.planned_qty;
                document.getElementById('summaryCompleted').textContent = batch.completed_qty;
                document.getElementById('summaryRejected').textContent = batch.rejected_qty;
                document.getElementById('summaryPending').textContent = batch.pending_qty;
                
                // Prefill received qty (started quantities) and make it read-only to avoid accidental edits when auto-selecting
                const receivedInput = document.getElementById('logReceived');
                if (receivedInput) {
                    receivedInput.value = batch.received_qty || 0;
                    receivedInput.readOnly = true;
                    receivedInput.classList.add('bg-light');
                }

                // Ensure calculation summary updates based on prefilled values
                updatePending();

                summaryDiv.style.display = 'block';
            }
        })
        .catch(error => console.error('Error loading batch details:', error));
}

// Update pending calculation
function updatePending() {
    const received = parseInt(document.getElementById('logReceived').value) || 0;
    const completed = parseInt(document.getElementById('logCompleted').value) || 0;
    const rejected = parseInt(document.getElementById('logRejected').value) || 0;
    const repair = parseInt(document.getElementById('logRepair').value) || 0;
    
    const total = received + completed + rejected + repair;
    const pending = Math.max(0, received - completed - rejected - repair);
    const efficiency = received > 0 ? Math.round((completed / received) * 100) : 0;
    
    document.getElementById('calcTotal').textContent = total;
    document.getElementById('calcNewPending').textContent = pending;
    document.getElementById('calcEfficiency').textContent = efficiency + '%';
}

function toggleContent(contentId) {
    console.log('Toggle called for:', contentId);
    var content = document.getElementById(contentId);
    
    if (!content) {
        console.error('Content element not found:', contentId);
        return;
    }
    
    if (content.style.display === 'none' || content.style.display === '') {
        content.style.display = 'block';
    } else {
        content.style.display = 'none';
    }
}

function toggleWO() {
    var content = document.getElementById('wo-content');
    if (content.style.display === 'none' || content.style.display === '') {
        content.style.display = 'block';
        document.querySelector('[onclick="toggleWO()"]').textContent = '−';
    } else {
        content.style.display = 'none';
        document.querySelector('[onclick="toggleWO()"]').textContent = '+';
    }
}

function toggleProcess() {
    var content = document.getElementById('process-content');
    if (content.style.display === 'none' || content.style.display === '') {
        content.style.display = 'block';
        document.querySelector('[onclick="toggleProcess()"]').textContent = '−';
    } else {
        content.style.display = 'none';
        document.querySelector('[onclick="toggleProcess()"]').textContent = '+';
    }
}

// Force load data immediately
window.addEventListener('load', function() {
    console.log('Window loaded, forcing data...');
    
    // Direct data insertion
    const treeContainer = document.getElementById('simpleTree');
    if (treeContainer) {
        console.log('Tree container found, inserting data...');
        treeContainer.innerHTML = `
            <div class="tree-container">
                <div class="tree-row wo-row">
                    <div class="tree-content">
                        <span class="toggle-btn" onclick="toggleData()">+</span>
                        <strong>WO-WO-2025-001</strong> | 1 products | 4 batches
                    </div>
                    <div class="tree-actions">
                        <button class="btn-simple btn-delete" onclick="deleteBatch(1)">Delete</button>
                    </div>
                </div>
                <div id="wo-content" class="tree-branch" style="display:none;">
                    <div class="tree-row product-row">
                        <div class="tree-content">
                            <strong>13" Knife</strong> (1K-075)
                        </div>
                        <div class="tree-actions">
                            <button class="btn-simple btn-delete" onclick="alert('Delete product')">Delete</button>
                        </div>
                    </div>
                    <div class="tree-branch">
                        <div class="tree-row process-row">
                            <div class="tree-content">
                                <span class="toggle-btn" onclick="alert('Process toggle')">+</span>
                                <strong>Laser Cutting</strong> (3 batches)
                            </div>
                            <div class="tree-actions">
                                <button class="btn-simple btn-delete" onclick="alert('Delete process')">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>`;
    } else {
        console.error('Tree container not found');
    }
});

function toggleData() {
    const content = document.getElementById('wo-content');
    if (content.style.display === 'none') {
        content.style.display = 'block';
    } else {
        content.style.display = 'none';
    }
}

</script>
