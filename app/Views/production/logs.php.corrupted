// Load work order products when work order is selected
function loadWorkOrderProducts() {
    const workOrderId = document.getElementById('batchWorkOrder').value;
    const productSelect = document.getElementById('batchProduct');
    
    console.log('Loading products for work order:', workOrderId);
    productSelect.innerHTML = '<option value="">Loading...</option>';
    
    if (!workOrderId) {
        productSelect.innerHTML = '<option value="">Select Product</option>';
        return;
    }
    
    fetch(`<?= base_url('/work-orders/') ?>${workOrderId}/products`, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
        .then(response => {
            console.log('Products response status:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Work order products response:', data);
            if (data.success) {
                const products = data.products || data.items || [];
                if (products.length > 0) {
                    productSelect.innerHTML = '<option value="">Select Product</option>' +
                        products.map(item => 
                            `<option value="${item.id}">${item.product_name || item.name} (${item.product_code || item.code}) - ${item.quantity_ordered} pcs</option>`
                        ).join('');
                } else {
                    productSelect.innerHTML = '<option value="">No products found in this work order</option>';
                }
            } else {
                console.error('Server error:', data.message);
                productSelect.innerHTML = '<option value="">Error: ' + (data.message || 'Failed to load products') + '</option>';
            }
        })
        .catch(error => {
            console.error('Error:', error);
            productSelect.innerHTML = '<option value="">Error loading products</option>';
        });
}

// Load product processes when product is selected
function loadProductProcesses() {
    const itemId = document.getElementById('batchProduct').value;
    const processSelect = document.getElementById('batchProcess');
    
    console.log('Loading processes for item ID:', itemId);
    processSelect.innerHTML = '<option value="">Loading...</option>';
    
    if (!itemId) {
        processSelect.innerHTML = '<option value="">Select Process</option>';
        return;
    }
    
    fetch(`<?= base_url('/production/ajax-get-item-processes/') ?>${itemId}`, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
        .then(response => {
            console.log('Processes response status:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Item processes response:', data);
            if (data.success) {
                const processes = data.processes || [];
                if (processes.length > 0) {
                    processSelect.innerHTML = '<option value="">Select Process</option>' +
                        processes.map(process => 
                            `<option value="${process.id}">${process.name} ${process.is_vendor_process ? '(Vendor)' : '(In-house)'}</option>`
                        ).join('');
                    
                    // Auto-generate batch code when process is selected. Use onchange assignment to avoid stacking listeners.
                    processSelect.onchange = generateBatchCode;
                } else {
                    processSelect.innerHTML = '<option value="">No processes assigned to this product</option>';
                }
            } else {
                console.error('Server error:', data.message);
                processSelect.innerHTML = '<option value="">Error: ' + (data.message || 'Failed to load processes') + '</option>';
            }
        })
        .catch(error => {
            console.error('Error:', error);
            // If server returned JSON error, try to extract message; otherwise show generic error
            try {
                // response.json() already attempted above; this catch likely has Error object only
                processSelect.innerHTML = '<option value="">Error loading processes</option>';
            } catch (e) {
                processSelect.innerHTML = '<option value="">Error loading processes</option>';
            }
        });
}

// Generate batch code
function generateBatchCode() {
    const woSelect = document.getElementById('batchWorkOrder');
    const processSelect = document.getElementById('batchProcess');
    const codeInput = document.getElementById('batchCode');
    
    if (woSelect.value && processSelect.value) {
        // Let backend generate the short code
        codeInput.value = 'Auto-generated based on selections';
    } else {
        codeInput.value = '';
    }
}

// Load active batches for log modal
function loadActiveBatches() {
    console.log('Loading active batches from:', `<?= base_url('/production/ajax-get-active-batches') ?>`);
    
    return fetch(`<?= base_url('/production/ajax-get-active-batches') ?>`, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
        .then(response => {
            console.log('Active batches response status:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Active batches response data:', data);
            if (data.success) {
                const batchSelect = document.getElementById('logBatch');
                if (batchSelect) {
                    batchSelect.innerHTML = '<option value="">Select Active Batch</option>' +
                        data.batches.map(batch => 
                            `<option value="${batch.id}">${batch.batch_code} - ${batch.product_name || 'N/A'} (${batch.process_name || 'N/A'})</option>`
                        ).join('');
                    console.log('Loaded', data.batches.length, 'active batches');
                } else {
                    console.error('logBatch select element not found');
                }
            } else {
                console.error('Server error loading active batches:', data.message);
                showError(data.message || 'Failed to load active batches');
            }
        })
        .catch(error => {
            console.error('Error loading active batches:', error);
            showError('Network error loading active batches');
        });
}

// Form submissions
document.getElementById('createBatchForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    
    // Don't send batch_code if it's just the placeholder text
    const batchCodeInput = document.getElementById('batchCode');
    if (batchCodeInput.value === 'Auto-generated based on selections') {
        formData.delete('batch_code');
    }
    
    fetch(`<?= base_url('/production/ajax-create-batch') ?>`, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-TOKEN': window.csrfToken || ''
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showSuccess('Batch created successfully!');
            bootstrap.Modal.getInstance(document.getElementById('createBatchModal')).hide();
            this.reset();
            loadProductionData();
            loadActiveBatches();
        } else {
            showError(data.message || 'Failed to create batch');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showError('Network error creating batch');
    });
});

document.getElementById('addLogForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Validate quantities before submission
    if (!validateQuantities()) {
        return;
    }
    
    const formData = new FormData(this);
    
    // Use the hidden batch ID field value
    const batchId = document.getElementById('logBatchId').value;
    if (!batchId) {
        showError('Batch ID is required');
        return;
    }
    
    // Override the batch_id in form data to use the hidden field
    formData.set('batch_id', batchId);
    
    fetch(`<?= base_url('/production/ajax-add-log') ?>`, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-TOKEN': window.csrfToken || ''
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showSuccess('Production log added successfully!');
            bootstrap.Modal.getInstance(document.getElementById('addLogModal')).hide();
            this.reset();
            loadHierarchicalData(); // Reload the tree
        } else {
            showError(data.message || 'Failed to add log');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showError('Network error adding log');
    });
});

// Quantity validation function
function validateQuantities() {
    const received = parseInt(document.getElementById('logReceived').value) || 0;
    const accepted = parseInt(document.getElementById('logAccepted').value) || 0;
    const rejected = parseInt(document.getElementById('logRejected').value) || 0;
    const repair = parseInt(document.getElementById('logRepair').value) || 0;
    
    let isValid = true;
    
    // Clear previous errors
    clearValidationErrors();
    
    // Check if accepted quantity is negative
    if (accepted < 0) {
        showFieldError('acceptedError', 'Accepted quantity cannot be negative');
        isValid = false;
    }
    
    // Check if received quantity is negative
    if (received < 0) {
        showFieldError('receivedError', 'Received quantity cannot be negative');
        isValid = false;
    }
    
    // Check if rejected quantity is negative
    if (rejected < 0) {
        showFieldError('rejectedError', 'Rejected quantity cannot be negative');
        isValid = false;
    }
    
    // Check if repair quantity is negative
    if (repair < 0) {
        showFieldError('repairError', 'Repair quantity cannot be negative');
        isValid = false;
    }
    
    // Check if accepted + rejected + repair exceeds received
    const totalProcessed = accepted + rejected + repair;
    if (totalProcessed > received) {
        showFieldError('acceptedError', 'Total processed (' + totalProcessed + ') cannot exceed received (' + received + ')');
        isValid = false;
    }
    
    // Check if accepted exceeds received
    if (accepted > received) {
        showFieldError('acceptedError', 'Accepted quantity cannot exceed received quantity');
        isValid = false;
    }
    
    // Get planned quantity from batch summary for validation
    const plannedQty = parseInt(document.getElementById('summaryPlanned').textContent) || 0;
    if (received > plannedQty) {
        showFieldError('receivedError', 'Received quantity cannot exceed planned quantity (' + plannedQty + ')');
        isValid = false;
    }
    
    return isValid;
}

function clearValidationErrors() {
    const acceptedError = document.getElementById('acceptedError');
    const receivedError = document.getElementById('receivedError');
    const rejectedError = document.getElementById('rejectedError');
    const repairError = document.getElementById('repairError');
    
    if (acceptedError) acceptedError.textContent = '';
    if (receivedError) receivedError.textContent = '';
    if (rejectedError) rejectedError.textContent = '';
    if (repairError) repairError.textContent = '';
    
    // Remove invalid class
    const logAccepted = document.getElementById('logAccepted');
    const logReceived = document.getElementById('logReceived');
    const logRejected = document.getElementById('logRejected');
    const logRepair = document.getElementById('logRepair');
    
    if (logAccepted) logAccepted.classList.remove('is-invalid');
    if (logReceived) logReceived.classList.remove('is-invalid');
    if (logRejected) logRejected.classList.remove('is-invalid');
    if (logRepair) logRepair.classList.remove('is-invalid');
}

function showFieldError(errorId, message) {
    const errorElement = document.getElementById(errorId);
    if (errorElement) {
        errorElement.textContent = message;
    }
    
    // Add invalid class to corresponding input
    const fieldId = errorId.replace('Error', '');
    let inputElement = null;
    
    if (fieldId === 'accepted') {
        inputElement = document.getElementById('logAccepted');
    } else if (fieldId === 'received') {
        inputElement = document.getElementById('logReceived');
    } else if (fieldId === 'rejected') {
        inputElement = document.getElementById('logRejected');
    } else if (fieldId === 'repair') {
        inputElement = document.getElementById('logRepair');
    }
    
    if (inputElement) {
        inputElement.classList.add('is-invalid');
    }
}

