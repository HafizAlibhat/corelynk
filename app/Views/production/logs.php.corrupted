};

// Load production data for main table
function loadProductionData() {
    console.log('loadProductionData called');
    // show loading spinner
    const loadingEl = document.getElementById('batchLoading');
    const countEl = document.getElementById('batchCount');
    if (loadingEl) loadingEl.style.display = 'inline-block';
    if (countEl) { countEl.style.display = 'none'; countEl.textContent = ''; }
    
    const filterForm = document.getElementById('filterForm');
    if (!filterForm) {
        console.error('filterForm element not found');
        return;
    }
    
    const formData = new FormData(filterForm);
    const params = new URLSearchParams(formData);
    
    const url = `<?= base_url('/production/ajax-get-batches') ?>?${params}`;
    console.log('Loading production data from:', url);
    
    fetch(url, {
        method: 'GET',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/json'
        }
    })
        .then(response => {
            console.log('Response status:', response.status);
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Response data:', data);
            if (data.success) {
                renderProductionTable(data.batches);
                // set batch count if present
                try {
                    const uniqueCount = (data.batches || []).length;
                    if (countEl) { countEl.textContent = uniqueCount; countEl.style.display = 'inline-block'; }
                } catch(e) { /* ignore */ }
                if (data.message && data.batches.length === 0) {
                    console.log('Info:', data.message);
                }
            } else {
                console.error('Server error:', data.message);
                showError(data.message || 'Failed to load production data');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showError('Network error loading production data');
        })
        .finally(() => {
            if (loadingEl) loadingEl.style.display = 'none';
            // Re-enable page scroll after content render
            ensureScrollEnabled();
        });
}

// Render production table
function renderProductionTable(batches) {
    const tbody = document.getElementById('productionTableBody');

    if (!batches || batches.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="9" class="text-center text-muted py-4">
                    <i class="bi bi-inbox display-6"></i>
                    <div class="mt-2">No production batches found</div>
                    <small>Start a new batch to begin production tracking</small>
                </td>
            </tr>
        `;
        return;
    }

    // Group batches by work order
    const groups = {};
    batches.forEach(b => {
        const wo = b.wo_number || 'Unassigned';
        if (!groups[wo]) {
            let header = 'Unassigned';
            if (b.wo_number && b.wo_number.trim() !== '') {
                header = b.wo_number;
                if (b.customer_name && b.customer_name.trim() !== '' && b.customer_name !== 'N/A') {
                    header += ` — ${b.customer_name}`;
                }
            }
            groups[wo] = { header: header, items: [] };
        }
        groups[wo].items.push(b);
    });

    let html = '';
    let idx = 0;
    for (const woKey in groups) {
        const group = groups[woKey];
        const gid = `wo_${idx++}`;

        // Work order header row with toggle (no nested tbody; use classes on rows)
        html += `
            <tr class="table-secondary wo-header" data-group="${gid}">
                <td colspan="9" style="vertical-align: middle;">
                    <button type="button" class="me-3 expand-toggle" onclick="toggleWorkOrder('${gid}', this); return false;" aria-expanded="false" aria-controls="${gid}">
                        <span class="expand-icon" aria-hidden="true">+</span>
                    </button>
                    <strong>${escapeHtml(group.header)}</strong>
                </td>
            </tr>
            <!-- Group-specific column headings (hidden/shown with group) -->
            <tr class="group-columns ${gid}" style="display: none;">
                <th>Batch Code</th>
                <th>Work Order</th>
                <th>Product</th>
                <th>Process</th>
                <th class="text-center">Planned Qty</th>
                <th>Progress</th>
                <th>Status</th>
                <th>Last Update</th>
                <th>Actions</th>
            </tr>
        `;

        group.items.forEach(batch => {
            const pct = batch.planned_qty && batch.planned_qty > 0 ? Math.round((batch.completed_qty / batch.planned_qty) * 100) : 0;
            html += `
                <tr class="wo-item ${gid}" style="display: none;">
                    <td>
                        <span class="fw-medium">${escapeHtml(batch.batch_code)}</span>
                        <br><small class="text-muted">ID: ${batch.id}</small>
                    </td>
                    <td>
                        <div class="fw-medium">${escapeHtml(batch.wo_number || '')}</div>
                        <small class="text-muted">${escapeHtml(batch.customer_name || '')}</small>
                    </td>
                    <td>
                        <div class="fw-medium truncate">${escapeHtml(batch.product_name || '')}</div>
                        <small class="text-muted">${escapeHtml(batch.product_code || '')}</small>
                    </td>
                    <td>
                        <div class="truncate">${escapeHtml(batch.process_name || '')}</div>
                        <small class="text-muted">
                            ${batch.is_vendor_process 
                                ? (batch.vendor_name && batch.vendor_name.trim() !== '' 
                                    ? escapeHtml(batch.vendor_name) 
                                    : 'Vendor') 
                                : 'In-house'}
                        </small>
                    </td>
                    <td class="text-center">
                        <div class="fw-bold">${batch.planned_qty || 0}</div>
                        <small class="text-muted">pcs</small>
                    </td>
                    <td>
                        <div class="progress mb-1" style="height: 8px;">
                            <div class="progress-bar bg-success" style="width: ${pct}%"></div>
                        </div>
                        <small class="text-muted">${batch.completed_qty || 0}/${batch.planned_qty || 0} (${pct}%)</small>
                    </td>
                    <td>
                        <span class="badge status-badge bg-${getStatusColor(batch.status)}">${batch.status === 'in_progress' ? 'In Progress' : (batch.status === 'completed' ? 'Completed' : escapeHtml(batch.status))}</span>
                    </td>
                    <td>
                        <div>${escapeHtml(batch.last_log_date || 'No Update Yet')}</div>
                        <small class="text-muted">
                            ${
                                (typeof batch.days_since_update === 'number') 
                                    ? `${batch.days_since_update} day${batch.days_since_update === 1 ? '' : 's'} ago`
                                    : (
                                        batch.last_log_date 
                                            ? escapeHtml(String(batch.days_since_update || '')) 
                                            : '—'
                                      )
                            }
                        </small>
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-primary" onclick="viewBatchDetails(${batch.id})" title="View Details">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button type="button" class="btn btn-outline-success" onclick="addLogToBatch(${batch.id})" title="Add Log">
                                <i class="bi bi-journal-plus"></i>
                            </button>
                            <button type="button" class="btn btn-outline-danger" onclick="deleteBatch(${batch.id}, this)" title="Delete Batch">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
    }

    tbody.innerHTML = html;
}

// Utility to escape HTML in JS strings (very small helper)
function escapeHtml(str) {
    if (!str) return '';
    return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

// Toggle work order group
function toggleWorkOrder(groupId, caller) {
    // Show / hide rows that have class equal to the groupId
    const rows = document.querySelectorAll('.wo-item.' + groupId);
    const headerRows = document.querySelectorAll('.group-columns.' + groupId);
    if (!rows || rows.length === 0) return;
    const icon = caller.querySelector('.expand-icon');
    // Use computed style to detect actual visibility (handles '' and table-row correctly)
    const firstRow = rows[0];
    const comp = window.getComputedStyle(firstRow);
    const visible = comp && comp.display !== 'none';
    if (visible) {
        rows.forEach(r => r.style.display = 'none');
        if (headerRows && headerRows.length) headerRows.forEach(h => h.style.display = 'none');
        if (icon) icon.textContent = '+';
        try { caller.setAttribute('aria-expanded', 'false'); } catch(e){}
        try { caller.closest('tr')?.classList.remove('active'); } catch(e){}
    } else {
        // use explicit table-row to ensure rows are shown correctly in all browsers/tables
        rows.forEach(r => r.style.display = 'table-row');
        if (headerRows && headerRows.length) headerRows.forEach(h => h.style.display = 'table-row');
        if (icon) icon.textContent = '\u2212';
        try { caller.setAttribute('aria-expanded', 'true'); } catch(e){}
        try { caller.closest('tr')?.classList.add('active'); } catch(e){}
    }
}

// Delete batch via AJAX
window.deleteBatch = function(batchId) {
    console.log('deleteBatch called, batchId:', batchId);
    if (!batchId || batchId === 'null') {
        alert('Invalid batch ID');
        return;
    }
    
    if (!confirm('Are you sure you want to delete this batch? This action cannot be undone.')) {
        console.log('User cancelled deletion');
        return;
    }
    
    console.log('User confirmed deletion, proceeding...');
    
    fetch('<?= base_url('production/ajax-delete-batch') ?>', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ batch_id: batchId })
    })
    .then(response => response.json())
    .then(data => {
        console.log('Delete response:', data);
        if (data.success) {
            alert('Batch deleted successfully');
            loadHierarchicalData();
        } else {
            alert('Error: ' + (data.message || 'Failed to delete batch'));
        }
    })
    .catch(error => {
        console.error('Delete error:', error);
        alert('Error deleting batch');
    });
};
        showError('Network error deleting batch');
        btn.disabled = false;
    }
}

// Helper functions
function normalizeStatus(status) {
    if (!status) return '';
    return String(status).trim().toLowerCase().replace(/\s+/g, '_');
}

function getStatusColor(status) {
    const key = normalizeStatus(status);
    const colors = {
        'planned': 'secondary',
        'in_progress': 'primary',
        'completed': 'success',
        'on_hold': 'secondary'
    };
    return colors[key] || 'secondary';
}

