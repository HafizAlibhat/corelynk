# ==========================================================

# Corelynk .gitignore

# ==========================================================

# -------------------------

# OS Files

# -------------------------

.DS_Store
.AppleDouble
.LSOverride
._*

Thumbs.db
ehthumbs.db
Desktop.ini

$RECYCLE.BIN/

*.cab
*.msi
*.msm
*.msp

*.lnk

*~

.directory

.Trash-*

# -------------------------

# Environment Files

# -------------------------

.env
.env.*

!.env.example

.vagrant
Vagrantfile

env/
production.env

# -------------------------

# Writable Directories

# -------------------------

writable/cache/*
!writable/cache/index.html

writable/logs/*
!writable/logs/index.html

writable/session/*
!writable/session/index.html

writable/uploads/*
!writable/uploads/index.html

writable/debugbar/*
!writable/debugbar/index.html

writable/backups/

writable/sync-reports/

writable/*.txt

# -------------------------

# Uploads

# -------------------------

public/uploads/

# -------------------------

# Temporary Files

# -------------------------

php_errors.log

_tmp*

tmp/

cookiejar.txt

# -------------------------

# Backup Files

# -------------------------

backup/

backups/

# -------------------------

# Database Dumps

# -------------------------

*.sql.gz

# -------------------------

# User Guide

# -------------------------

user_guide_src/build/*

user_guide_src/cilexer/build/*

user_guide_src/cilexer/dist/*

user_guide_src/cilexer/pycilexer.egg-info/*

# -------------------------

# Test Files

# -------------------------

tests/coverage*

phpunit

# -------------------------

# Composer

# -------------------------

vendor/

# -------------------------

# IDE Files

# -------------------------

_modules/*

.php-version

.idea/

*.iml

/nbproject/

/build/

/nbbuild/

/dist/

/nbdist/

/nbactions.xml

/nb-configuration.xml

/.nb-gradle/

*.tmlanguage.cache

*.tmPreferences.cache

*.stTheme.cache

*.sublime-workspace

*.sublime-project

.phpintel

/api/

.vscode/

/results/

/phpunit*.xml

# -------------------------

# Docker Overrides

# -------------------------

docker-compose.override.yml

# -------------------------

# Never Commit Debug Files

# -------------------------

app/Config/Routes.php.corrupt_backup

database/debug_queries.sql

debug_*.php

test.php
